# ============================================
# Autonomous DevOps & Auto-Fix Agent
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# Google Gemini API Key
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model name to use (free tier supports gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Maximum number of fix attempts before the agent gives up
MAX_FIX_ATTEMPTS=5

# Docker container name for the sandbox
SANDBOX_CONTAINER_NAME=devops-agent-sandbox

# Path to the workspace inside the Docker container
SANDBOX_WORKSPACE_PATH=/workspace

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
